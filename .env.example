# TechMirai AI — Environment Variables
# Copy this file to .env.local for local dev. Set the same vars in Vercel
# project settings > Environment Variables for production.
# DO NOT commit .env.local to git.

# === SMTP (transactional email) ============================================
# Recommended providers: Resend, SendGrid, Postmark, Amazon SES, Gmail SMTP.
# For Resend (easiest):  https://resend.com
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx

# For Gmail (app password required, not your login password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your.address@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# === Email addresses =======================================================
# FROM_EMAIL  - The address that appears in the From header. Must be on a
#               domain you've verified with your SMTP provider (e.g. on Resend
#               you must verify techmirai-ai.com first).
# NOTIFICATION_EMAIL - Where new lead notifications are sent. Usually the same
#                      as your business inbox.

FROM_EMAIL=info@techmirai-ai.com
NOTIFICATION_EMAIL=info@techmirai-ai.com

# === CORS ==================================================================
# Set this to your production domain to lock the API to your own site only.
# Use * during local development.

ALLOWED_ORIGIN=https://techmirai-ai.com
